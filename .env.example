# ============================================================
# MEGA TOOLS — PRODUCTION ENVIRONMENT VARIABLES (Render)
# ============================================================
# Copy this file to .env and replace with your real values.

# ---- DATABASE ----
MONGODB_URI=mongodb+srv://your_db_user:your_password@your_cluster.mongodb.net/your_db?retryWrites=true&w=majority
MONGODB_DB=megamastartools

# ---- SECURITY ----
JWT_SECRET=your_jwt_secret_change_in_production
WEBHOOK_SECRET_KEY=your_webhook_secret_change_in_production
ADMIN_API_TOKEN=your_admin_token_change_in_production
BCRYPT_SALT_ROUNDS=12

# ---- EMAIL (Brevo) ----
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_EMAIL=noreply@megatools.site
BREVO_SENDER_NAME=Mega Tools Support

# ---- SERVER ----
PORT=5000
NODE_ENV=production
CLIENT_URL=https://mega-tools.online

# ---- SESSION TIMINGS ----
SESSION_TIMEOUT_MS=120000
HEARTBEAT_INTERVAL_MS=30000
AUTO_TRASH_INTERVAL_MS=600000
INBOX_CLEAN_INTERVAL_MS=86400000
TRASH_MAX_AGE_DAYS=30
TRIAL_DURATION_MS=300000

# ---- RATE LIMITING ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=500

# ---- LOGIN SECURITY ----
LOGIN_ATTEMPTS_MAX=5
LOGIN_ATTEMPTS_WINDOW_MS=900000